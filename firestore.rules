rules_version = '2';

/**
 * PassMark Firestore Security Rules
 *
 * This ruleset implements a robust, multi-tier authorization model.
 * It prioritizes "Authorization Independence" by ensuring that documents contain the necessary 
 * metadata (IDs, roles) to make security decisions.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Robust Admin Check. 
     * Verifies user exists in legacy roles_admin OR their profile has role 'admin'.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isSubscriber() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionStatus in ['active', 'premium', 'free'];
    }

    // --- COLLECTION RULES ---

    /**
     * @description User Profiles.
     * Allow discovery for marketplace mentors. Admins manage all.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();

      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) && request.resource.data.userId == userId) || isAdmin();
        allow update: if (isExistingOwner(userId) && request.resource.data.userId == resource.data.userId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Legacy roles collections for backward compatibility.
     */
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    match /roles_campus_rep/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Hierarchical University Content.
     */
    match /universities/{universityId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /departments/{departmentId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();

        match /courses/{courseId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isAdmin();

          match /pastQuestions/{pastQuestionId} {
            allow get, list: if isAdmin() || (isSubscriber() && resource.data.verified == true);
            allow create, update, delete: if isAdmin();
          }
        }
      }
    }

    /**
     * @description Tutor Marketplace & Mentor Discovery.
     */
    match /tutors/{tutorId} {
      allow get, list: if isAdmin() || isOwner(tutorId) || (resource != null && resource.data.approved == true);
      allow create: if (isOwner(tutorId) && request.resource.data.userId == tutorId && request.resource.data.approved == false) || isAdmin();
      allow update: if (isExistingOwner(tutorId) && request.resource.data.approved == resource.data.approved) || isAdmin();
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.tutorId == request.auth.uid));
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.studentId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource != null && (resource.data.studentId == request.auth.uid || resource.data.tutorId == request.auth.uid));
      allow delete: if isAdmin();
    }

    /**
     * @description Verified Mentor Reputations.
     */
    match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
        allow update, delete: if isAdmin();
    }

    /**
     * @description Professional Academic Signals (Messaging).
     */
    match /messages/{messageId} {
        allow read: if isAdmin() || (isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.tutorId == request.auth.uid));
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.tutorId == request.auth.uid);
        allow delete: if isAdmin();
    }

    /**
     * @description Flat Past Questions Collection (Primary).
     */
    match /pastQuestions/{pastQuestionId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.verified == true);
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Campus Representative Commissions.
     */
    match /commissions/{commissionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.repId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
  }
}
